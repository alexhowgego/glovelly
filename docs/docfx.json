{
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "toc.yml"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "assets/**",
          "mcp-tools.json",
          "CNAME"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/glovelly"
    ],
    "globalMetadata": {
      "_appName": "Glovelly Handbook",
      "_appTitle": "Glovelly Handbook",
      "_appLogoPath": "assets/gordon-192.png",
      "_appFaviconPath": "assets/gordon-192.png",
      "_appFooter": "<span>Glovelly Handbook. Built from the repo with <a href=\"https://dotnet.github.io/docfx\">DocFX</a>.</span>",
      "_disableContribution": true,
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/alexhowgego/glovelly",
        "branch": "main"
      }
    },
    "sitemap": {
      "baseUrl": "https://docs.glovelly.net/"
    }
  }
}
